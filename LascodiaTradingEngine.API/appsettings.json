{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "WriteDbConnection": "Host=127.0.0.1;Database=LascodiaTradingEngineDb;Username=postgres;Password=${DB_PASSWORD};Maximum Pool Size=200;Minimum Pool Size=10;Connection Idle Lifetime=300;Timeout=30",
    "ReadDbConnection": "Host=127.0.0.1;Database=LascodiaTradingEngineDb;Username=postgres;Password=${DB_PASSWORD};Maximum Pool Size=200;Minimum Pool Size=10;Connection Idle Lifetime=300;Timeout=30"
  },
  "BrokerType": "rabbitmq",
  "RabbitMQConfig": {
    "Host": "127.0.0.1",
    "Username": "${RABBITMQ_USERNAME}",
    "Password": "${RABBITMQ_PASSWORD}",
    "QueueName": "lascodia-trading-engine-queue"
  },
  "EmailAlertOptions": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "EnableSsl": true,
    "FromAddress": "alerts@lascodia.com",
    "FromName": "Lascodia Trading Engine"
  },
  "TelegramAlertOptions": {
    "BotToken": "",
    "TimeoutSeconds": 10
  },
  "WebhookAlertOptions": {
    "TimeoutSeconds": 30,
    "SharedSecret": ""
  },
  "WorkerGroups": {
    "EnableAll": true,
    "CoreTrading": true,
    "MarketData": true,
    "RiskMonitoring": true,
    "MLTraining": true,
    "MLMonitoring": true,
    "Backtesting": true,
    "Alerts": true
  },
  "MarketRegimeOptions": {
    "Period": 14,
    "TrendingAdxThreshold": 25,
    "TrendingMaxVolatility": 20,
    "RangingAdxThreshold": 20,
    "RangingMaxVolatility": 10,
    "HighVolatilityThreshold": 30,
    "ConfidenceDivisor": 50
  },
  "CorrelationGroupOptions": {
    "Groups": [
      ["EURUSD", "GBPUSD", "AUDUSD", "NZDUSD"],
      ["USDCHF", "USDJPY", "USDCAD"],
      ["EURJPY", "GBPJPY", "AUDJPY"]
    ]
  },
  "RiskCheckerOptions": {
    "MLDisagreementMinConfidence": 0.70
  },
  "StrategyEvaluatorOptions": {
    "DefaultLotSize": 0.01,
    "BreakoutConfidence": 0.65,
    "BreakoutExpiryMinutes": 15,
    "MaCrossoverConfidence": 0.70,
    "MaCrossoverExpiryMinutes": 60,
    "RsiReversionExpiryMinutes": 30
  },
  "PortfolioOptimizerOptions": {
    "MaxPortfolioKelly": 0.25,
    "MaxPerTradeKelly": 0.05,
    "CorrelationGroupCap": 0.10,
    "MinLotSize": 0.01
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "Encryption": {
    "Key": "${ENCRYPTION_KEY}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "lascodia-trading-engine",
    "Audience": "lascodia-trading-engine-api",
    "ExpirationMinutes": 480
  },
  "BridgeOptions": {
    "Enabled": false,
    "BindAddress": "0.0.0.0",
    "Port": 5082,
    "AdvertisedHost": "",
    "UseTls": false,
    "TcpBacklog": 128,
    "MaxTotalConnections": 200,
    "MaxConnectionsPerAccount": 10
  },
  "DeepSeekOptions": {
    "ApiKey": "",
    "BaseUrl": "https://api.deepseek.com/v1",
    "Model": "deepseek-chat",
    "TimeoutSeconds": 30,
    "MaxTokensPerResponse": 200,
    "MaxCallsPerHour": 60,
    "Temperature": 0.1,
    "HeadlineBatchSize": 8
  },
  "NewsSentimentOptions": {
    "Enabled": false,
    "PollingIntervalHours": 2.0,
    "RssFeedUrls": [],
    "MaxHeadlineAgeDays": 1,
    "EconomicEventLookbackHours": 24,
    "EconomicEventLookaheadHours": 6,
    "SkipWeekends": true,
    "MaxCallsPerCycle": 10,
    "DeduplicationWindowHours": 4
  }
}
