# Lascodia Trading Engine — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
#
# Docker-compose uses ${VAR:-default} syntax: values here override defaults.
# For local development without docker, use appsettings.Development.json instead.

# ── Database ──────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-min-32-chars-required!

# ── Encryption ────────────────────────────────────────────
ENCRYPTION_KEY=change-me-in-production-min-32-chars-required!
